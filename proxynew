-- MOVEMENT HOOK (Fly + Auto Farm)
AddHook("onsendpacket", "Movement", function(pkt_type, pkt_data)
    if pkt_type ~= PKT_WALK then return false end
    
    -- Auto Farm Roulette (Find & Path)
    if pkt_data:find("action|join_request") == nil then
        for _, tile in pairs(GetTiles()) do
            if tile.fg == 3898 then -- Roulette ID
                local tx, ty = tile.x//32, tile.y//32
                local px, py = GetLocal().pos.x//32, GetLocal().pos.y//32
                if math.abs(tx-px) < 5 and math.abs(ty-py) < 5 then
                    -- Near roulette, auto spin
                    SendPacket(PKT_CHAT, "action|dialog_return\ndialog_name|popup\nbuttonClicked|spin")
                end
            end
        end
    end
    
    return false
end)

-- SPIN DETECTOR (REME/QEME)
AddHook("onvariant", "SpinDetector", function(var)
    if var[0] == "OnTalkBubble" and var[2]:find("spun the wheel") then
        local spin_text = var[2]:match("got `(%d+)")
        if spin_text then
            local num = tonumber(spin_text)
            local result = reme_mode and (math.floor(num/10) + num%10)%10 or num%10
            Chat("`6SPIN: `2"..num.." `0→ `9"..result)
        end
    end
    return false
end)

