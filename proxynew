-- GLOBAL VARIABLES
local reme = false
local wrench_pull = false
local fly_active = false

-- UTILITY FUNCTIONS
function Chat(msg)
    SendPacket(2, "action|input\n|text|" .. msg)
end

function DropItem(item_id, count)
    SendPacket(2, "action|dialog_return\ndialog_name|drop\nitem_drop|"..item_id.."|\nitem_count|"..count)
end

-- MAIN COMMAND HANDLER
AddHook("onsendpacket", "ProxyHandler", function(type, data)
    if type ~= 2 then return false end  -- Only chat packets
    
    -- PROXY MENU
    if data:find("/proxy") then
        ProxyOpen()
        Chat("`6⚡ PROXY v3.1 LOADED!")
        return true
    end
    
    -- RE MEKE MODE
    if data:find("/remek") or data:find("/reme") then
        reme = not reme
        Chat(reme and "`6REME MODE `2ON!" or "`4REME MODE `0OFF")
        return true
    end
    
    -- FAST DROP 99 WL
    if data:find("/drop99") or data:find("/d99") then
        DropItem(242, 99)  -- World Lock ID
        Chat("`499 `9WL `0DROPPED!")
        return true
    end
    
    -- FAST WRENCH
    if data:find("/wrench") or data:find("/wp") then
        wrench_pull = not wrench_pull
        Chat(wrench_pull and "`2PULL MODE `0ON! `9Right-click players" or "`4PULL MODE `0OFF")
        return true
    end
    
    -- FLY MODE
    if data:find("/fly") then
        fly_active = not fly_active
        Chat(fly_active and "`6FLY MODE `2ON! `0Hold SPACE/JUMP" or "`4FLY MODE `0OFF")
        return true
    end
    
    -- QUICK SKINS
    if data:find("/black") then
        SendPacket(2, "action|dialog_return\ndialog_name|skinpicker\nred|0\ngreen|0\nblue|0\ntransparency|0")
        Chat("`bBLACK SKIN `2SET!")
        return true
    end
    
    if data:find("/pink") then
        SendPacket(2, "action|dialog_return\ndialog_name|skinpicker\nred|255\ngreen|105\nblue|180\ntransparency|0")
        Chat("`#PINK SKIN `2SET!")
        return true
    end
    
    -- WRENCH AUTO-PULL
    if wrench_pull and data:find("action|wrench\nnetid|(%d+)") then
        local netid = data:match("netid|(%d+)")
        SendPacket(2, "action|dialog_return\ndialog_name|popup\nnetID|"..netid.."|\nbuttonClicked|pull")
        Chat("`2PULLED `6" .. netid)
        return true
    end
    
    return false
end)

-- SPIN DETECTOR (REME/QEME)
AddHook("onvariant", "SpinHook", function(vars)
    if vars[0] == "OnTalkBubble" and vars[2]:find("spun the wheel") then
        local spin_num = vars[2]:match("got `([0-9])")
        if spin_num and reme then
            local num = tonumber(spin_num)
            local reme_result = (math.floor(num/10) + num%10) % 10
            Chat("`6SPIN:`2 " .. num .. " `0→ `9REME:`6 " .. reme_result)
        end
    end
    return false
end)

