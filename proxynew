-- MAIN HOOK (Super Simple)
AddHook("onsendpacket",function(t,d)
if t~=2 then return end

-- /proxy menu
if d:find("/proxy") then
SendPacket(2,"action|input\n|text|`9Commands: `0/drop99 `9/remek `9/black `9/pink `9/fly")
return true
end

-- Drop 99 WL
if d:find("/drop99") or d:find("/d99") then
Drop99WL()
return true
end

-- Skins
if d:find("/black") then
BlackSkin()
return true
end

if d:find("/pink") then
PinkSkin()
return true
end

-- Fly
if d:find("/fly") then
FlyMode()
return true
end

return false
end)

-- AUTO START
Proxy()
